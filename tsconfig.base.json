{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@payn/types": ["packages/types/src"],
      "@payn/config": ["packages/config/src"],
      "@payn/utils": ["packages/utils/src"],
      "@payn/ui": ["packages/ui/src"]
    }
  }
}

